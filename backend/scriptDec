pipeline {
    agent any

    stages {

        stage('Clone Repository') {
            steps {
                echo 'Cloning ria branch...'
                git branch: 'ria', url: 'https://github.com/UdayDewani/Handicraft-Ecommerce.git'
            }
        }

        stage('Install Backend Dependencies') {
            steps {
                dir('backend') {
                    bat 'echo MONGO_URL=mongodb+srv://ria:ria123@cluster0.6mywxum.mongodb.net/ecommerce333?appName=Cluster0 > .env'
                    bat 'echo SECRET_KEY=your-secret-key-here >> .env'
                    bat 'npm install'
                }
            }
        }

        stage('Install Frontend Dependencies') {
            steps {
                dir('frontend') {
                    bat 'npm install'
                }
            }
        }

        stage('Run Backend Server') {
            steps {
                dir('backend') {
                    bat 'start cmd /k npm start'
                }
            }
        }

        stage('Run Frontend Server') {
            steps {
                dir('frontend') {
                    bat 'start cmd /k npm start'
                }
            }
        }

        stage('Build Completed') {
            steps {
                echo 'Build & Run Successful from ria branch!'
            }
        }
    }
}
